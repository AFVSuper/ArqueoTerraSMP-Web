# Base de datos SQLite local. Las rutas relativas parten de la raiz del proyecto.
DATABASE_PATH=.data/minecraft-guide.db

# Cuenta creada la primera vez que se ejecuta `npm run db:seed`.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambiar-esta-clave

# Datos visibles en la web publica.
NEXT_PUBLIC_SERVER_NAME=Brújula Arcaica
NEXT_PUBLIC_SERVER_ADDRESS=play.tuservidor.net
NEXT_PUBLIC_SITE_URL=http://localhost:3000
